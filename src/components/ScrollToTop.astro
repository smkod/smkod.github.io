---
import { ArrowUp } from 'lucide-astro';
---
<button
  id="scroll-to-top"
  class="fixed bottom-8 right-8 p-3 rounded-full bg-accent text-bg-light shadow-lg opacity-0 translate-y-10 invisible transition-all duration-300 z-50 hover:scale-110 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 dark:focus:ring-offset-bg-dark"
  aria-label="Scroll to top"
>
  <ArrowUp size={24} />
</button>

<script>
  const scrollBtn = document.getElementById('scroll-to-top');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 400) {
      scrollBtn?.classList.remove('opacity-0', 'translate-y-10', 'invisible');
      scrollBtn?.classList.add('opacity-100', 'translate-y-0', 'visible');
    } else {
      scrollBtn?.classList.add('opacity-0', 'translate-y-10', 'invisible');
      scrollBtn?.classList.remove('opacity-100', 'translate-y-0', 'visible');
    }
  });

  scrollBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>