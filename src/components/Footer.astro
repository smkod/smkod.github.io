---
import { Github, Linkedin, Mail } from 'lucide-astro';

const { dict } = Astro.props;
---

<footer id="contact" class="py-24 px-6 text-center border-t border-bg-light/30 reveal-on-scroll">
  <div class="max-w-xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold text-text-main mb-6 tracking-tight">{dict.title}</h2>
    <p class="text-text-muted mb-12 text-lg leading-relaxed">
      {dict.description}
    </p>
    
    <a 
      href="mailto:sacasco99@gmail.com" 
      class="inline-block border-2 border-accent text-accent px-10 py-4 rounded font-bold hover:bg-accent/10 transition-all mb-16"
      aria-label="Send an email"
    >
      {dict.cta}
    </a>

    <div class="flex justify-center gap-8 mb-8 text-text-muted">
      <div class="relative group">
        <a href="https://github.com/smkod" target="_blank" aria-label="GitHub Profile" class="block hover:text-accent hover:-translate-y-1 transition-all duration-300">
          <Github size={24} />
        </a>
        <div class="absolute -top-10 left-1/2 -translate-x-1/2 px-2 py-1 bg-bg-light text-text-main text-xs rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 group-hover:delay-[1000ms] whitespace-nowrap border border-black/10 dark:border-white/10 shadow-lg">
          GitHub
        </div>
      </div>
      
      <div class="relative group">
        <a href="https://linkedin.com/in/samuelcasco" target="_blank" aria-label="LinkedIn Profile" class="block hover:text-accent hover:-translate-y-1 transition-all duration-300">
          <Linkedin size={24} />
        </a>
        <div class="absolute -top-10 left-1/2 -translate-x-1/2 px-2 py-1 bg-bg-light text-text-main text-xs rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 group-hover:delay-[1000ms] whitespace-nowrap border border-black/10 dark:border-white/10 shadow-lg">
          LinkedIn
        </div>
      </div>

      <div class="relative group">
        <a href="mailto:sacasco99@gmail.com" aria-label="Email Me" class="block hover:text-accent hover:-translate-y-1 transition-all duration-300">
          <Mail size={24} />
        </a>
        <div class="absolute -top-10 left-1/2 -translate-x-1/2 px-2 py-1 bg-bg-light text-text-main text-xs rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 group-hover:delay-[1000ms] whitespace-nowrap border border-black/10 dark:border-white/10 shadow-lg">
          Email
        </div>
      </div>
    </div>

    <p class="text-text-muted text-xs font-mono">
      {dict.designed}
    </p>
  </div>
</footer>
