---
const { dict } = Astro.props;
---

<section id="experience" class="py-24 px-6 max-w-4xl mx-auto reveal-on-scroll">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-3xl font-bold text-text-main">{dict.title}</h2>
    <div class="h-[1px] bg-bg-light flex-grow"></div>
  </div>

  <div class="space-y-16">
    {dict.jobs.map((exp: any) => (
      <div class="relative pl-8 border-l-2 border-bg-light hover:border-accent transition-colors">
        <div class="absolute w-4 h-4 bg-accent rounded-full -left-[9px] top-1 shadow-[0_0_10px_rgba(100,255,218,0.5)]"></div>
        
        <div class="mb-6">
          <h3 class="text-2xl font-bold text-text-main mb-1">{exp.company}</h3>
        </div>

        <div class="space-y-10 mb-8">
          {exp.roles.map((role: any) => (
            <div class="relative">
              <div class="absolute w-2 h-2 bg-bg-light rounded-full -left-[37px] top-2 border border-accent"></div>
              <div class="mb-4">
                <h4 class="text-lg font-semibold text-text-main">{role.title}</h4>
                <p class="text-accent font-mono text-sm">{role.date}</p>
              </div>
              <ul class="space-y-3">
                {role.description.map((item: string) => (
                  <li class="text-text-muted flex items-start gap-2 text-sm leading-relaxed">
                    <span class="text-accent mt-1">▹</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="flex flex-wrap gap-2">
          {exp.tech.map((t: string) => (
            <span class="bg-bg-light text-accent px-3 py-1 rounded-full text-xs font-mono">
              {t}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
