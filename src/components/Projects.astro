---
import { ExternalLink, Github } from 'lucide-astro';

const { dict } = Astro.props;

interface Project {
  title: string;
  description: string;
  github?: string;
  external?: string;
  type: 'career' | 'personal';
  tech: string[];
}
---

<section id="projects" class="py-24 px-6 max-w-6xl mx-auto reveal-on-scroll">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-3xl font-bold text-text-main">{dict.title}</h2>
    <div class="h-[1px] bg-bg-light flex-grow"></div>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {dict.items.map((project: Project, i: number) => (
      <div class="bg-bg-light p-8 rounded-lg flex flex-col h-full group hover:-translate-y-2 transition-all duration-300 border border-transparent hover:border-accent/30 shadow-xl reveal-on-scroll" style={`transition-delay: ${i * 100}ms`}>
        <div class="flex justify-end mb-6">
          <div class="flex gap-4 text-text-muted group-hover:text-text-main">
            {project.github && project.type !== 'career' && (
              <a href={project.github} aria-label={`View ${project.title} source code on GitHub`} target="_blank" class="hover:text-accent hover:scale-110 transition-all">
                <Github size={20} />
              </a>
            )}
            {project.external && (
              <a href={project.external} aria-label={`Visit ${project.title} live site`} target="_blank" class="hover:text-accent hover:scale-110 transition-all">
                <ExternalLink size={20} />
              </a>
            )}
          </div>
        </div>

        <h3 class="text-xl font-bold text-text-main mb-2 group-hover:text-accent transition-colors line-clamp-2 h-16">
          {project.title}
        </h3>
        
        <p class="text-text-muted text-sm mb-6 leading-relaxed line-clamp-4 h-28">
          {project.description}
        </p>

        <div class="mt-auto">
          <div class="mb-4">
            <span class={`text-[10px] uppercase tracking-[0.2em] font-bold ${
              project.type === 'career' 
              ? 'text-blue-400' 
              : 'text-purple-400'
            }`}>
              {project.type === 'career' ? dict.badgeCareer : dict.badgePersonal} {dict.badgeProject}
            </span>
          </div>

          <div class="flex flex-wrap gap-x-4 gap-y-2 text-xs font-mono text-text-muted h-10 overflow-hidden">
            {project.tech.map((t: string) => (
              <span class="group-hover:text-accent/80 transition-colors">{t}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
