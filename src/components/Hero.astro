---
import { ChevronRight, Download } from 'lucide-astro';
const { dict } = Astro.props;
---

<section id="hero" class="min-h-screen flex flex-col justify-center px-6 pt-[84px] md:pt-20 reveal-on-scroll">
  <div class="max-w-4xl mx-auto">
    <p class="text-accent font-mono mb-4 animate-fade-in">{dict.greeting}</p>
    <h1 class="text-5xl md:text-7xl font-bold text-text-main mb-4 tracking-tight">
      {dict.name}
    </h1>
    <h2 class="text-4xl md:text-6xl font-bold text-text-muted mb-8 leading-tight">
      {dict.subtitle}
    </h2>
    <p class="text-text-muted max-w-xl text-lg md:text-xl mb-12 leading-relaxed" set:html={dict.description} />
    
    <div class="flex flex-wrap gap-4">
      <a 
        href="#projects" 
        class="bg-transparent border-2 border-accent text-accent px-8 py-4 rounded font-bold hover:bg-accent/10 transition-all flex items-center gap-2 group"
      >
        {dict.cta}
        <ChevronRight size={20} class="group-hover:translate-x-1 transition-transform" />
      </a>
      <a 
        href="/resume.pdf" 
        target="_blank"
        class="bg-bg-light border-2 border-bg-light text-text-main px-8 py-4 rounded font-bold hover:border-accent/50 transition-all flex items-center gap-2 group"
      >
        {dict.resume}
        <Download size={20} class="group-hover:-translate-y-1 transition-transform" />
      </a>
    </div>
  </div>
</section>

<style>
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
