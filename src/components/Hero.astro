---
import { ChevronRight, Download } from 'lucide-astro';
const { dict } = Astro.props;
---

<section id="hero" class="min-h-screen flex flex-col justify-center px-6 pt-[84px] md:pt-20 reveal-on-scroll">
  <div class="max-w-4xl mx-auto">
    <p class="text-accent font-mono mb-4 animate-fade-in">{dict.greeting}</p>
    <h1 class="text-4xl md:text-7xl font-bold text-text-main mb-4 tracking-tight">
      {dict.name}
    </h1>
    <h2 class="text-4xl md:text-6xl font-bold text-text-muted mb-8 leading-tight">
      {dict.subtitle}
    </h2>
    <p class="text-text-muted max-w-xl text-lg md:text-xl mb-12 leading-relaxed" set:html={dict.description} />
    
    <div class="flex flex-wrap gap-4">
      <a 
        href="#projects" 
        class="bg-accent text-bg-dark px-8 py-4 rounded font-bold hover:scale-[1.02] transition-all duration-300 flex items-center gap-2 group shadow-lg shadow-accent/20 hover:shadow-accent/40"
      >
        {dict.cta}
        <ChevronRight size={20} class="group-hover:translate-x-0.5 transition-transform duration-300" />
      </a>
      <a 
        href={dict.resumeLink} 
        download
        target="_blank"
        class="relative overflow-hidden bg-white/5 dark:bg-white/[0.03] backdrop-blur-md border border-black/10 dark:border-white/10 text-text-main px-8 py-4 rounded font-bold hover:scale-[1.02] hover:border-accent/40 transition-all duration-300 flex items-center gap-2 group shadow-sm"
      >
        <div class="absolute inset-0 bg-gradient-to-tr from-accent/10 via-transparent to-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <span class="relative z-10 flex items-center gap-2">
          {dict.resume}
          <Download size={20} class="group-hover:translate-y-[-1px] transition-transform duration-300" />
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
