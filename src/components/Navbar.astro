---
import { Github, Linkedin, Menu, X } from 'lucide-astro';
import LanguagePicker from './LanguagePicker.astro';
import ThemeToggle from './ThemeToggle.astro';

const { dict, currentLang } = Astro.props;
---

<nav id="navbar" class="fixed top-0 w-full z-40 bg-transparent backdrop-blur-sm py-6 transition-all duration-300 border-b border-transparent">
  <div class="max-w-6xl mx-auto px-6 flex justify-between items-center">
    <a href="#" class="text-accent font-bold text-xl tracking-tighter hover:opacity-80 transition-opacity z-50">
      <span><span>{`{{`}</span> SC <span>{`}}`}</span></span>
    </a>
    
    <div class="hidden md:flex items-center gap-8 text-sm font-medium">
      <a href="#about" class="hover:text-accent transition-colors text-text-muted">{dict.about}</a>
      <a href="#experience" class="hover:text-accent transition-colors text-text-muted">{dict.experience}</a>
      <a href="#projects" class="hover:text-accent transition-colors text-text-muted">{dict.projects}</a>
      {/* <a href="https://dev.to/smkod" target="_blank" class="hover:text-accent transition-colors text-text-muted">{dict.articles}</a> */}
      <a href="#contact" class="hover:text-accent transition-colors text-text-muted">{dict.contact}</a>
    </div>

    <div class="flex items-center gap-4 text-text-muted z-50">
      <ThemeToggle />
      <LanguagePicker currentLang={currentLang} />
      <div class="hidden md:flex items-center gap-4 border-l border-black/10 dark:border-white/10 pl-4">
        <div class="relative group">
          <a href="https://github.com/smkod" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors block">
            <Github size={20} />
          </a>
          <div class="absolute top-10 left-1/2 -translate-x-1/2 px-2 py-1 bg-bg-light text-text-main text-xs rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 group-hover:delay-[1000ms] whitespace-nowrap border border-black/10 dark:border-white/10 shadow-lg">
            GitHub
          </div>
        </div>
        <div class="relative group">
          <a href="https://linkedin.com/in/samuelcasco" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors block">
            <Linkedin size={20} />
          </a>
          <div class="absolute top-10 left-1/2 -translate-x-1/2 px-2 py-1 bg-bg-light text-text-main text-xs rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 group-hover:delay-[1000ms] whitespace-nowrap border border-black/10 dark:border-white/10 shadow-lg">
            LinkedIn
          </div>
        </div>
      </div>
      
      <!-- Hamburger Button (Mobile Only) -->
      <button id="mobile-menu-btn" class="md:hidden p-2 hover:text-accent transition-colors" aria-label="Open menu">
        <Menu size={24} />
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-bg-dark/60 backdrop-blur-xl z-[100] flex flex-col justify-center items-center opacity-0 invisible transition-all duration-500">
  <button id="close-menu-btn" class="absolute top-6 right-6 p-2 text-text-muted hover:text-accent transition-colors" aria-label="Close menu">
    <X size={32} />
  </button>
  
  <div class="flex flex-col items-center gap-6 text-3xl font-bold">
    <a href="#about" class="mobile-link group flex items-center gap-4 text-text-main hover:text-accent transition-all duration-300">
      <span class="text-accent text-sm font-mono opacity-50 group-hover:opacity-100">01.</span>
      {dict.about}
    </a>
    <a href="#experience" class="mobile-link group flex items-center gap-4 text-text-main hover:text-accent transition-all duration-300">
      <span class="text-accent text-sm font-mono opacity-50 group-hover:opacity-100">02.</span>
      {dict.experience}
    </a>
      <a href="#projects" class="mobile-link group flex items-center gap-4 text-text-main hover:text-accent transition-all duration-300">
      <span class="text-accent text-sm font-mono opacity-50 group-hover:opacity-100">03.</span>
      {dict.projects}
    </a>
    {/* <a href="https://dev.to/smkod" target="_blank" class="mobile-link group flex items-center gap-4 text-text-main hover:text-accent transition-all duration-300">
      <span class="text-accent text-sm font-mono opacity-50 group-hover:opacity-100">04.</span>
      {dict.articles}
    </a> */}
    <a href="#contact" class="mobile-link group flex items-center gap-4 text-text-main hover:text-accent transition-all duration-300">
      <span class="text-accent text-sm font-mono opacity-50 group-hover:opacity-100">05.</span>
      {dict.contact}
    </a>
  </div>

  <div class="flex items-center gap-8 mt-20">
    <a href="https://github.com/smkod" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent hover:-translate-y-1 transition-all duration-300">
      <Github size={32} />
    </a>
    <a href="https://linkedin.com/in/samuelcasco" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent hover:-translate-y-1 transition-all duration-300">
      <Linkedin size={32} />
    </a>
  </div>
</div>

<script>
  const nav = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('bg-bg-light/90', 'backdrop-blur-md', 'py-4', 'border-black/5', 'dark:border-white/5');
      nav?.classList.remove('bg-transparent', 'backdrop-blur-sm', 'py-6', 'border-transparent');
    } else {
      nav?.classList.add('bg-transparent', 'backdrop-blur-sm', 'py-6', 'border-transparent');
      nav?.classList.remove('bg-bg-light/90', 'backdrop-blur-md', 'py-4', 'border-black/5', 'dark:border-white/5');
    }
  });

  // Mobile menu logic
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const closeMenuBtn = document.getElementById('close-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  const toggleMenu = () => {
    mobileMenu?.classList.toggle('opacity-0');
    mobileMenu?.classList.toggle('invisible');
    document.body.classList.toggle('overflow-hidden'); // Prevent scrolling when menu is open
  };

  mobileMenuBtn?.addEventListener('click', toggleMenu);
  closeMenuBtn?.addEventListener('click', toggleMenu);
  
  mobileLinks.forEach(link => {
    link.addEventListener('click', toggleMenu);
  });
</script>
